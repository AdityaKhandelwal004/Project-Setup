{
  "name": "obiemoney",
  "version": "1.0.0",
  "description": "ObieMoney Financial Management Platform Monorepo",
  "main": "index.js",
  "private": true,
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "build:packages": "pnpm -r --filter \"./packages/**\" --if-present run build",
    "dev": "pnpm -r --parallel --if-present run start",
    "dev:api": "pnpm --filter obiemoney-api run start",
    "dev:webpanel-one": "pnpm --filter obiemoney-webpanel-one run start",
    "dev:webpanel-two": "pnpm --filter obiemoney-webpanel-two run start",
    "dev:client": "pnpm run dev:webpanel-one",
    "dev:server": "pnpm run dev:api",
    "lint": "pnpm -r --if-present run lint",
    "lint:fix": "pnpm -r --if-present run lint -- --fix",
    "test": "pnpm -r --if-present run test",
    "clean": "pnpm -r --if-present run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "pnpm -r --if-present run type-check",
    "install:all": "pnpm install",
    "clean:all": "pnpm --recursive exec rm -rf node_modules && rm -rf node_modules && rm -rf pnpm-lock.yaml"
  },
  "keywords": [
    "monorepo",
    "fintech",
    "financial-management",
    "obiemoney",
    "react",
    "typescript"
  ],
  "author": "ObieMoney Team",
  "license": "ISC",
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@mono/eslint-config": "workspace:*",
    "@mono/typescript-config": "workspace:*",
    "eslint": "^9.30.1",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3"
  }
}
