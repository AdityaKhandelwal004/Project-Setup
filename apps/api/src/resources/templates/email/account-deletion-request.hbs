<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#if emailTitle}}{{emailTitle}}{{else}}Obiemoney{{/if}}</title>
    <!--[if mso]>
    <style type="text/css">
        table { border-collapse: collapse; }
        .divider { height: 1px !important; }
    </style>
    <![endif]-->
</head>

<body style="margin: 0; padding: 0; width: 100%; background-color: #f5f5f5; font-family: Arial, sans-serif;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td align="center" style="padding: 40px 20px;">
                <table role="presentation" width="700" cellpadding="0" cellspacing="0"
                    style="max-width: 700px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

                    {{> header}}

                    <!-- CONTENT -->
                    <tr>
                        <td style="padding: 40px 60px;">
                            <h1
                                style="margin: 0 0 15px 0; font-size: 24px; font-weight: 700; color: #2C2A5C; line-height: 1.3;">
                                Account Deletion Request
                            </h1>

                            <p style="margin: 0 0 20px 0; font-size: 15px; color: #666666; line-height: 1.6;">
                                A request has been submitted to permanently delete the following Obiemoney account.
                            </p>

                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                                style="margin: 20px 0; background-color: #f9f9f9; border-radius: 8px;">
                                <tr>
                                    <td style="padding: 20px;">
                                        <p style="margin: 0 0 8px 0; font-size: 14px; color: #666666;">
                                            <strong>Name:</strong> {{name}}</p>
                                        <p style="margin: 0 0 8px 0; font-size: 14px; color: #666666;">
                                            <strong>Email:</strong> {{email}}</p>
                                        <p style="margin: 0 0 8px 0; font-size: 14px; color: #666666;"><strong>User
                                                ID:</strong> {{id}}</p>
                                        <p style="margin: 0; font-size: 14px; color: #666666;"><strong>Requested
                                                On:</strong> {{requestDate}}</p>
                                    </td>
                                </tr>
                            </table>

                            {{#if reason}}
                            <p style="margin: 20px 0 5px 0; font-size: 14px; color: #2C2A5C;"><strong>Reason for
                                    Deletion:</strong></p>
                            <p style="margin: 0 0 20px 0; font-size: 14px; color: #666666; line-height: 1.6;">
                                {{reason}}
                            </p>
                            {{/if}}

                            <p
                                style="margin: 20px 0 0 0; font-size: 14px; color: #666666; line-height: 1.6; border-top: 1px solid #eeeeee; padding-top: 20px;">
                                Please review this request and proceed according to internal policies. No changes have
                                been made to the account yet.
                            </p>

                            <p style="margin-top: 25px; font-size: 12px; color: #999999;">
                                Automated notification from Obiemoney System.
                            </p>
                        </td>
                    </tr>

                    {{> footer}}

                </table>
            </td>
        </tr>
    </table>
</body>

</html>