<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#if emailTitle}}{{emailTitle}}{{else}}Template{{/if}}</title>
    <!--[if mso]>
    <style type="text/css">
        table { border-collapse: collapse; }
        .divider { height: 1px !important; }
    </style>
    <![endif]-->
</head>

<body
    style="margin: 0; padding: 0; width: 100%; background-color: #F5F5F5; font-family: Arial, sans-serif; -webkit-font-smoothing: antialiased;">
    <!-- Wrapper Table -->
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
        style="background-color: #F5F5F5;">
        <tr>
            <td align="center" style="padding: 40px 20px;">
                <!-- Container Table -->
                <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="700"
                    style="max-width: 700px; background-color: #FFFFFF; border-radius: 12px; overflow: hidden;">
                    <!-- HEADER -->
                    {{> header}}
                    <!-- MAIN CONTENT -->
                    <tr>
                        <td align="center" style="padding: 30px 60px;">
                            <h1
                                style="margin: 0; font-size: 26px; font-weight: 700; color: #2C2A5C; line-height: 1.3; font-family: Arial, sans-serif;">
                                Hi {{firstName}},
                            </h1>
                            <h1
                                style="margin: 0 0 20px 0; font-size: 26px; font-weight: 700; color: #2C2A5C; line-height: 1.3; font-family: Arial, sans-serif;">
                                Your Journey to Financial Clarity Starts Now
                            </h1>

                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                Welcome to Template! You’ve just taken the first step toward building a resilient
                                financial future. We’re thrilled to be your digital companion.
                            </p>

                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                Our structured roadmap will help you eliminate debt, automate your savings, and
                                optimize your investments—moving you from complexity to confidence.
                            </p>

                            <table border="0" cellspacing="0" cellpadding="0" align="center" style="margin-top: 10px;">
                                <tr>
                                    <td align="center" bgcolor="#100937"
                                        style="padding: 12px 30px; border-radius: 6px;">
                                        <a href="{{url}}" target="_blank"
                                            style="font-family: Arial, sans-serif; font-size: 16px; font-weight: bold; color: #FFFFFF; text-decoration: none; display: inline-block;">
                                            Start My Journey
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p
                                style="margin: 20px 0 0 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                We’re excited to see what you’ll achieve.<br />
                                <strong>Team Template</strong>
                            </p>
                        </td>
                    </tr>
                    <!-- FOOTER -->
                    {{> footer}}
                </table>
            </td>
        </tr>
    </table>
</body>

</html>