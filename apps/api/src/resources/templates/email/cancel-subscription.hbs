<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#if emailTitle}}{{emailTitle}}{{else}}Obiemoney{{/if}}</title>
    <!--[if mso]>
    <style type="text/css">
        table { border-collapse: collapse; }
        .divider { height: 1px !important; }
    </style>
    <![endif]-->
</head>

<body
    style="margin: 0; padding: 0; width: 100%; background-color: #F5F5F5; font-family: Arial, sans-serif; -webkit-font-smoothing: antialiased;">
    <!-- Wrapper Table -->
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
        style="background-color: #F5F5F5;">
        <tr>
            <td align="center" style="padding: 40px 20px;">
                <!-- Container Table -->
                <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="700"
                    style="max-width: 700px; background-color: #FFFFFF; border-radius: 12px; overflow: hidden;">
                    <!-- HEADER -->
                    {{> header}}

                    <tr>
                        <td align="center" style="padding: 40px 60px;">
                            <h1
                                style="margin: 0 0 20px 0; font-size: 26px; font-weight: 700; color: #2C2A5C; line-height: 1.3;">
                                Subscription Cancellation Confirmed
                            </h1>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; text-align: left;">
                                Hi {{firstName}},
                            </p>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; text-align: left;">
                                We're confirming that your <strong>{{planName}}</strong> subscription has been
                                cancelled. While your journey with our premium tools is coming to an end, your path to
                                financial clarity remains our priority.
                            </p>

                            {{#if accessUntil}}
                            <div
                                style="margin: 25px 0; padding: 20px; background-color: #F9F9F9; border-radius: 8px; text-align: left; border-left: 4px solid #6A40E5;">
                                <p style="margin: 0; font-size: 14px; color: #666666; line-height: 1.5;">
                                    <strong>Access Note:</strong> You will continue to have full access to your 9-step
                                    financial roadmap and automation features until <strong>{{accessUntil}}</strong>.
                                </p>
                            </div>
                            {{/if}}

                            <p
                                style="margin: 0 0 20px 0; font-size: 15px; color: #666666; line-height: 1.6; text-align: left;">
                                After this date, your account will move to our basic plan. You can return to your
                                premium dashboard and reactivate your automated budgeting tools at any time.
                            </p>

                            <table border="0" cellspacing="0" cellpadding="0" align="center" style="margin-top: 10px;">
                                <tr>
                                    <td align="center" bgcolor="#100937"
                                        style="padding: 12px 35px; border-radius: 6px;">
                                        <a href="{{url}}" target="_blank"
                                            style="font-family: Arial, sans-serif; font-size: 16px; font-weight: bold; color: #FFFFFF; text-decoration: none; display: inline-block;">
                                            Go to Dashboard
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p
                                style="margin: 25px 0 0 0; font-size: 14px; color: #999999; line-height: 1.6; text-align: left;">
                                Thank you for letting us be part of your financial growth. We’re always here if you
                                decide to jump back in.
                            </p>
                        </td>
                    </tr>
                    {{> footer}}
                </table>
            </td>
        </tr>
    </table>
</body>

</html>