<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#if emailTitle}}{{emailTitle}}{{else}}Obiemoney{{/if}}</title>
    <!--[if mso]>
    <style type="text/css">
        table { border-collapse: collapse; }
        .divider { height: 1px !important; }
    </style>
    <![endif]-->
</head>

<body
    style="margin: 0; padding: 0; width: 100%; background-color: #f5f5f5; font-family: Arial, sans-serif; -webkit-font-smoothing: antialiased;">
    <!-- Wrapper Table -->
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
        style="background-color: #f5f5f5;">
        <tr>
            <td align="center" style="padding: 40px 20px;">
                <!-- Container Table -->
                <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="700"
                    style="max-width: 700px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

                    <!-- HEADER -->
                    {{> header}}

                    <!-- MAIN CONTENT -->
                    <tr>
                        <td align="center" style="padding: 30px 60px;">
                            <h1
                                style="margin: 0 0 20px 0; font-size: 26px; font-weight: 700; color: #2C2A5C; line-height: 1.3; font-family: Arial, sans-serif;">
                                Your Path to Financial Clarity is Active!
                            </h1>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif; text-align: left;">
                                Hi {{firstName}},
                            </p>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif; text-align: left;">
                                Welcome to <strong>{{planName}}</strong>! By subscribing, you’ve unlocked the full
                                potential of Obiemoney, from automated budgeting to our guided financial roadmap.
                                We are excited to help you move from complexity to confidence.
                            </p>

                            <div
                                style="margin: 25px 0; padding: 20px; background-color: #F9F7FF; border-radius: 8px; border: 1px solid #E6E0FF; text-align: left;">
                                {{#if amount}}
                                <p
                                    style="margin: 0 0 10px 0; font-size: 14px; color: #2C2A5C; font-family: Arial, sans-serif;">
                                    <strong>Payment Confirmed:</strong> {{amount}} {{currency}}
                                </p>
                                {{/if}}
                                {{#if validityEndDate}}
                                <p style="margin: 0; font-size: 14px; color: #2C2A5C; font-family: Arial, sans-serif;">
                                    <strong>Access Valid Until:</strong> {{validityEndDate}}
                                </p>
                                {{/if}}
                            </div>

                            <p
                                style="margin: 0 0 20px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif; text-align: left;">
                                Your digital money hub is now fully operational. You can start automating your savings,
                                tracking your safety net, and exploring our educational resources right away.
                            </p>

                            <table border="0" cellspacing="0" cellpadding="0" align="center" style="margin-top: 10px;">
                                <tr>
                                    <td align="center" bgcolor="#100937"
                                        style="padding: 12px 40px; border-radius: 6px;">
                                        <a href="{{url}}" target="_blank"
                                            style="font-family: Arial, sans-serif; font-size: 16px; font-weight: bold; color: #ffffff; text-decoration: none; display: inline-block;">
                                            Open My Dashboard
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p
                                style="margin: 25px 0 0 0; font-size: 14px; color: #999999; line-height: 1.6; font-family: Arial, sans-serif; text-align: left;">
                                Need help getting started with your roadmap? Our support team is always here to guide
                                you.
                            </p>
                        </td>
                    </tr>

                    <!-- FOOTER -->
                    {{> footer}}

                </table>
            </td>
        </tr>
    </table>
</body>

</html>