<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invoice</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      color: #333;
      font-size: 10px;
      background-color: #f4f4f4;
    }

    .container {
      width: 100%;
      max-width: 190mm;
      margin: 0 auto;
      padding: 20px;
      background-color: #fff;
      box-sizing: border-box;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
    }

    .header-left h1 {
      font-size: 24px;
      margin: 0;
      color: #333;
      text-transform: uppercase;
    }

    .header-left p {
      margin: 5px 0 0 0;
      font-size: 12px;
      color: #777;
    }

    .header-right img {
      height: 30px;
    }

    .section {
      display: flex;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    .section-column {
      flex: 1;
      margin-right: 20px;
    }

    .section-column:last-child {
      margin-right: 0;
    }

    .section-column h3 {
      font-size: 12px;
      /* UPDATED this line */
      margin: 10px 0 10px 0;
      /* Was margin: 0 0 10px 0; */
      color: #555;
      border-bottom: 1px solid #eee;
      padding-bottom: 5px;
    }

    .section-column p {
      margin: 2px 0;
    }

    .line-item-header {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      border-bottom: 1px solid #eee;
      margin-top: 30px;
      font-weight: bold;
      color: #555;
    }

    .line-item-header div {
      flex: 1;
    }

    .line-item-header .amount,
    .line-item-header .total-amount {
      flex: 0.5;
      text-align: right;
    }

    .line-item {
      display: flex;
      justify-content: space-between;
      padding: 10px 0;
      border-bottom: 1px solid #eee;
    }

    .line-item div {
      flex: 1;
    }

    .line-item .amount,
    .line-item .total-amount {
      flex: 0.5;
      text-align: right;
    }

    .description-text {
      font-size: 10px;
      color: #777;
    }

    .summary-section {
      width: 300px;
      margin-left: auto;
      margin-top: 20px;
      border-top: 1px solid #eee;
      padding-top: 10px;
    }

    .summary-row {
      display: flex;
      justify-content: space-between;
      padding: 3px 0;
    }

    .summary-row .label {
      font-weight: normal;
    }

    .summary-row .value {
      font-weight: normal;
    }

    .summary-row.total .label,
    .summary-row.total .value {
      font-weight: bold;
      font-size: 12px;
      padding-top: 5px;
    }

    .summary-row.amount-due {
      border-top: 1px solid #333;
      padding-top: 10px;
      margin-top: 10px;
    }

    .summary-row.amount-due .label,
    .summary-row.amount-due .value {
      font-weight: bold;
      font-size: 14px;
    }

    .footer-message {
      margin-top: 50px;
      font-size: 12px;
      text-align: left;
      padding-left: 0;
      color: #555;
    }

    .footer-details {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 80px;
      padding-top: 15px;
      border-top: 1px solid #eee;
      font-size: 10px;
      color: #777;
    }

    @page {
      size: A4;
      margin: 5mm;
    }

    /* Print-specific styles */
    @media print {
      body {
        background: #fff;
      }

      .container {
        border: none;
        box-shadow: none;
        margin: 0;
        padding: 10mm;
        width: auto;
        max-width: none;
      }
    }
  </style>
</head>

<body
  style="margin: 0; padding: 0; width: 100%; background-color: #f5f5f5; font-family: Arial, sans-serif; -webkit-font-smoothing: antialiased;">
  <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f5f5f5;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="700"
          style="max-width: 700px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

          <tr>
            <td style="padding: 40px 60px; background-color: #ffffff; border-bottom: 1px solid #eeeeee;">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td align="left">
                    <h1
                      style="margin: 0; font-size: 28px; font-weight: 700; color: #2C2A5C; font-family: Arial, sans-serif;">
                      INVOICE</h1>
                    <p style="margin: 5px 0 0 0; font-size: 16px; color: #666666; font-family: Arial, sans-serif;">
                      #{{invoiceNumber}}</p>
                  </td>
                  <td align="right">
                    <img src="https://cdn.obiemoney.com/user-email-icons/obie-logo.png" alt="Obiemoney Logo" width="120"
                      style="display: block; border: 0;" />
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="padding: 30px 60px;">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td width="30%" valign="top" style="font-family: Arial, sans-serif;">
                    <h3 style="margin: 0 0 5px 0; font-size: 13px; color: #999999; text-transform: uppercase;">Issued
                    </h3>
                    <p style="margin: 0 0 15px 0; font-size: 14px; color: #333333;">{{issueDate}}</p>
                    <h3 style="margin: 0 0 5px 0; font-size: 13px; color: #999999; text-transform: uppercase;">Due</h3>
                    <p style="margin: 0; font-size: 14px; color: #333333;">{{dueDate}}</p>
                  </td>
                  <td width="35%" valign="top"
                    style="border-left: 1px solid #eeeeee; padding-left: 20px; font-family: Arial, sans-serif;">
                    <h3 style="margin: 0 0 5px 0; font-size: 13px; color: #999999; text-transform: uppercase;">Billed to
                    </h3>
                    <p style="margin: 0; font-size: 14px; color: #333333; font-weight: bold;">{{customer.name}}</p>
                    <p style="margin: 2px 0; font-size: 14px; color: #666666;">{{customer.email}}</p>
                    {{#if customer.address}}<p style="margin: 2px 0; font-size: 14px; color: #666666;">
                      {{customer.address}}</p>{{/if}}
                  </td>
                  <td width="35%" valign="top"
                    style="border-left: 1px solid #eeeeee; padding-left: 20px; font-family: Arial, sans-serif;">
                    <h3 style="margin: 0 0 5px 0; font-size: 13px; color: #999999; text-transform: uppercase;">From</h3>
                    <p style="margin: 0; font-size: 14px; color: #333333; font-weight: bold;">{{company.name}}</p>
                    <p style="margin: 2px 0; font-size: 14px; color: #666666;">{{company.email}}</p>
                    <p style="margin: 2px 0; font-size: 12px; color: #999999;">TAX ID: {{company.taxId}}</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="padding: 0 60px;">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
                style="border-collapse: collapse;">
                <thead>
                  <tr style="border-bottom: 2px solid #2C2A5C;">
                    <td align="left"
                      style="padding: 10px 0; font-size: 13px; font-weight: bold; color: #2C2A5C; text-transform: uppercase;">
                      Description</td>
                    <td align="right"
                      style="padding: 10px 0; font-size: 13px; font-weight: bold; color: #2C2A5C; text-transform: uppercase;">
                      Amount</td>
                    <td align="right"
                      style="padding: 10px 0; font-size: 13px; font-weight: bold; color: #2C2A5C; text-transform: uppercase;">
                      Total</td>
                  </tr>
                </thead>
                <tbody>
                  {{#each lineItems}}
                  <tr style="border-bottom: 1px solid #eeeeee;">
                    <td align="left" style="padding: 15px 0;">
                      <p style="margin: 0; font-size: 15px; color: #333333; font-weight: bold;">{{description}}</p>
                      <p style="margin: 2px 0 0 0; font-size: 13px; color: #999999;">{{servicePeriod}}</p>
                    </td>
                    <td align="right" style="padding: 15px 0; font-size: 15px; color: #666666;">{{currency}} {{amount}}
                    </td>
                    <td align="right" style="padding: 15px 0; font-size: 15px; color: #333333; font-weight: bold;">
                      {{currency}} {{totalAmount}}</td>
                  </tr>
                  {{/each}}
                </tbody>
              </table>
            </td>
          </tr>

          <tr>
            <td align="right" style="padding: 30px 60px;">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="250">
                <tr>
                  <td align="left" style="padding: 5px 0; font-size: 14px; color: #666666;">Subtotal</td>
                  <td align="right" style="padding: 5px 0; font-size: 14px; color: #333333;">{{summary.currency}}
                    {{summary.subtotal}}</td>
                </tr>
                <tr>
                  <td align="left" style="padding: 5px 0; font-size: 14px; color: #666666;">Tax
                    ({{summary.taxPercent}}%)</td>
                  <td align="right" style="padding: 5px 0; font-size: 14px; color: #333333;">{{summary.currency}}
                    {{summary.taxAmount}}</td>
                </tr>
                <tr style="font-weight: bold; font-size: 18px; color: #2C2A5C;">
                  <td align="left" style="padding: 15px 0 5px 0; border-top: 1px solid #eeeeee;">Total</td>
                  <td align="right" style="padding: 15px 0 5px 0; border-top: 1px solid #eeeeee;">{{summary.currency}}
                    {{summary.total}}</td>
                </tr>
                <tr style="font-weight: bold; font-size: 15px; color: #6A40E5;">
                  <td align="left" style="padding: 5px 0;">Amount Due</td>
                  <td align="right" style="padding: 5px 0;">{{summary.currency}} {{summary.amountDue}}</td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td align="center" style="padding: 20px 60px 40px 60px;">
              <p style="margin: 0 0 20px 0; font-size: 14px; color: #666666; font-style: italic; line-height: 1.6;">
                {{footerMessage}}
              </p>
              <div style="font-size: 12px; color: #999999; border-top: 1px solid #eeeeee; padding-top: 20px;">
                <strong>{{company.name}}</strong> &nbsp;&bull;&nbsp; {{company.phone}} &nbsp;&bull;&nbsp;
                {{company.email}}
              </div>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>

</html>