<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#if emailTitle}}{{emailTitle}}{{else}}Template{{/if}}</title>
    <!--[if mso]>
    <style type="text/css">
        table { border-collapse: collapse; }
        .divider { height: 1px !important; }
    </style>
    <![endif]-->
</head>

<body
    style="margin: 0; padding: 0; width: 100%; background-color: #F5F5F5; font-family: Arial, sans-serif; -webkit-font-smoothing: antialiased;">
    <!-- Wrapper Table -->
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
        style="background-color: #F5F5F5;">
        <tr>
            <td align="center" style="padding: 40px 20px;">
                <!-- Container Table -->
                <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="700"
                    style="max-width: 700px; background-color: #FFFFFF; border-radius: 12px; overflow: hidden;">
                    <!-- HEADER -->
                    {{> header}}
                    <!-- MAIN CONTENT -->
                    <tr>
                        <td align="center" style="padding: 40px 60px;">
                            <h1
                                style="margin: 0 0 20px 0; font-size: 26px; font-weight: 700; color: #2C2A5C; line-height: 1.3;">
                                Password Updated Successfully
                            </h1>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; text-align: left;">
                                This email confirms that the password for your Template account has been changed. You
                                can now use your new credentials to continue your journey toward financial clarity.
                            </p>

                            <table border="0" cellspacing="0" cellpadding="0" align="center" style="margin: 20px 0;">
                                <tr>
                                    <td align="center" bgcolor="#100937"
                                        style="padding: 12px 35px; border-radius: 6px;">
                                        <a href="{{url}}" target="_blank"
                                            style="font-family: Arial, sans-serif; font-size: 16px; font-weight: bold; color: #FFFFFF; text-decoration: none; display: inline-block;">
                                            Log In to Dashboard
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <div
                                style="margin-top: 25px; padding-top: 20px; border-top: 1px solid #EEEEEE; text-align: left;">
                                <p style="margin: 0; font-size: 14px; color: #666666; line-height: 1.6;">
                                    <strong>Didn't authorize this change?</strong><br />
                                    If you did not request this update, please contact our support team immediately or
                                    secure your account through your settings to protect your financial data.
                                </p>
                            </div>
                        </td>
                    </tr>
                    <!-- FOOTER -->
                    {{> footer}}
                </table>
            </td>
        </tr>
    </table>
</body>

</html>