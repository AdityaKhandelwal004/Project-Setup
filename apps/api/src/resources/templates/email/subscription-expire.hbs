<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#if emailTitle}}{{emailTitle}}{{else}}Obiemoney{{/if}}</title>
    <!--[if mso]>
    <style type="text/css">
        table { border-collapse: collapse; }
        .divider { height: 1px !important; }
    </style>
    <![endif]-->
</head>

<body
    style="margin: 0; padding: 0; width: 100%; background-color: #f5f5f5; font-family: Arial, sans-serif; -webkit-font-smoothing: antialiased;">
    <!-- Wrapper Table -->
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
        style="background-color: #f5f5f5;">
        <tr>
            <td align="center" style="padding: 40px 20px;">
                <!-- Container Table -->
                <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="700"
                    style="max-width: 700px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

                    <!-- === 1. LOGO === -->
                    {{> header}}
                    <!-- === 2. DYNAMIC CONTENT SECTION === -->
                    <tr>
                        <td align="center" style="padding: 30px 60px;">
                            <h1
                                style="margin: 0 0 20px 0; font-size: 26px; font-weight: 700; color: #2C2A5C; line-height: 1.3; font-family: Arial, sans-serif;">
                                Don't Lose Your Financial Momentum
                            </h1>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                Hi {{firstName}},
                            </p>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                Your {{planName}} subscription expired{{#if expiredDate}} on {{expiredDate}}{{/if}}. To
                                ensure you don't lose access to your personalized roadmap and automation tools, your
                                account has been transitioned to our basic plan.
                            </p>

                            {{#if daysRemaining}}
                            <div
                                style="margin: 20px 0; padding: 15px; background-color: #FFF9F2; border: 1px solid #FFE6CC; border-radius: 8px;">
                                <p
                                    style="margin: 0; font-size: 15px; color: #CC7A00; line-height: 1.6; font-family: Arial, sans-serif;">
                                    <strong>Grace Period Active:</strong> You have {{daysRemaining}} days to renew and
                                    keep your premium insights active without interruption.
                                </p>
                            </div>
                            {{/if}}

                            <p
                                style="margin: 0 0 25px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                Staying committed to your financial habits is the key to long-term resilience. Renew
                                today to continue utilizing our debt elimination tools, savings automation, and
                                comprehensive financial dashboard.
                            </p>

                            <table border="0" cellspacing="0" cellpadding="0" align="center">
                                <tr>
                                    <td align="center" bgcolor="#100937"
                                        style="padding: 12px 30px; border-radius: 6px;">
                                        <a href="{{url}}" target="_blank"
                                            style="font-family: Arial, sans-serif; font-size: 16px; font-weight: bold; color: #ffffff; text-decoration: none; display: inline-block;">
                                            Renew My Subscription
                                        </a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    {{> footer}}
                </table>
</body>

</html>