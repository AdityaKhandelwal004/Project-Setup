<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#if emailTitle}}{{emailTitle}}{{else}}Obiemoney{{/if}}</title>
    <!--[if mso]>
    <style type="text/css">
        table { border-collapse: collapse; }
        .divider { height: 1px !important; }
    </style>
    <![endif]-->
</head>

<body
    style="margin: 0; padding: 0; width: 100%; background-color: #f5f5f5; font-family: Arial, sans-serif; -webkit-font-smoothing: antialiased;">
    <!-- Wrapper Table -->
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
        style="background-color: #f5f5f5;">
        <tr>
            <td align="center" style="padding: 40px 20px;">
                <!-- Container Table -->
                <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="700"
                    style="max-width: 700px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">
                    <tr>
                        <td align="center" style="padding: 3 0;">
                            <!-- === 1. LOGO === -->
                            {{> header}}
                            <!-- === 2. DYNAMIC CONTENT SECTION === -->
                    <tr>
                        <td align="center" style="padding: 30px 60px;" align="center">
                            <h1
                                style="margin: 0 0 20px 0; font-size: 26px; font-weight: 700; color: #2C2A5C; line-height: 1.3; font-family: Arial, sans-serif;">
                                Password Successfully Updated
                            </h1>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                Your password for your Obiemoney account has been successfully reset. You can now log in
                                and continue your journey toward financial clarity.
                            </p>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                If you did not perform this action, please secure your account by contacting our support
                                team immediately.
                            </p>

                            <table border="0" cellspacing="0" cellpadding="0" align="center" style="margin-top: 20px;">
                                <tr>
                                    <td align="center" bgcolor="#6A40E5"
                                        style="padding: 12px 35px; border-radius: 6px;">
                                        <a href="{{url}}" target="_blank"
                                            style="font-family: Arial, sans-serif; font-size: 16px; font-weight: bold; color: #ffffff; text-decoration: none; display: inline-block;">
                                            Log In to Dashboard
                                        </a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
            </td>
        </tr>

        <!-- FOOTER -->
        {{> footer}}

    </table>
    </td>
    </tr>
    </table>
</body>

</html>