<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#if emailTitle}}{{emailTitle}}{{else}}Obiemoney{{/if}}</title>
    <!--[if mso]>
    <style type="text/css">
        table { border-collapse: collapse; }
        .divider { height: 1px !important; }
    </style>
    <![endif]-->
</head>

<body
    style="margin: 0; padding: 0; width: 100%; background-color: #f5f5f5; font-family: Arial, sans-serif; -webkit-font-smoothing: antialiased;">
    <!-- Wrapper Table -->
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
        style="background-color: #f5f5f5;">
        <tr>
            <td align="center" style="padding: 40px 20px;">
                <!-- Container Table -->
                <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="700"
                    style="max-width: 700px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

                    <!-- HEADER -->
                    {{> header}}

                    <!-- MAIN CONTENT -->
                    <tr>
                        <td align="center" style="padding: 40px 60px;">
                            <h1
                                style="margin: 0 0 16px 0; font-size: 26px; font-weight: 700; color: #2C2A5C; line-height: 1.3;">
                                Security Verification
                            </h1>
                            <p
                                style="margin: 0 0 25px 0; font-size: 15px; color: #666666; line-height: 1.6; text-align: left;">
                                To protect your financial data, please use the secure code below to complete your
                                sign-in to <strong>Obiemoney</strong>.
                            </p>

                            <div>
                                <p
                                    style="font-size: 32px; font-weight: 800; letter-spacing: 6px; margin: 0; color: #2C2A5C; font-family: 'Courier New', Courier, monospace; text-align: center;">
                                    {{code}}
                                </p>
                            </div>

                            <p
                                style="margin: 25px 0 0 0; font-size: 14px; color: #999999; line-height: 1.5; text-align: left;">
                                This code is temporary and will expire in <strong>{{validity}} minutes</strong>. For
                                your security, never share this code with anyone.
                            </p>
                        </td>
                    </tr>

                    <tr>
                        <td align="center" style="padding: 0 60px 40px 60px;">
                            <div style="padding-top: 20px; border-top: 1px solid #eeeeee;">
                                <p
                                    style="margin: 0; font-size: 13px; color: #B0B0B0; line-height: 1.4; text-align: left;">
                                    <strong>Didn't try to sign in?</strong> If you did not initiate this request, your
                                    account may be at risk. Please contact our support team immediately.
                                </p>
                            </div>
                        </td>
                    </tr>

                    <!-- FOOTER -->
                    {{> footer}}

                </table>
            </td>
        </tr>
    </table>
</body>

</html>