<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#if emailTitle}}{{emailTitle}}{{else}}Obiemoney{{/if}}</title>
    <!--[if mso]>
    <style type="text/css">
        table { border-collapse: collapse; }
        .divider { height: 1px !important; }
    </style>
    <![endif]-->
</head>

<body
    style="margin: 0; padding: 0; width: 100%; background-color: #F5F5F5; font-family: Arial, sans-serif; -webkit-font-smoothing: antialiased;">
    <!-- Wrapper Table -->
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
        style="background-color: #F5F5F5;">
        <tr>
            <td align="center" style="padding: 40px 20px;">
                <!-- Container Table -->
                <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="700"
                    style="max-width: 700px; background-color: #FFFFFF; border-radius: 12px; overflow: hidden;">
                    <!-- HEADER -->
                    {{> header}}
                    <!-- MAIN CONTENT -->
                    <tr>
                        <td align="center" style="padding: 30px 60px;" align="left">
                            <h1
                                style="margin: 0 0 20px 0; font-size: 26px; font-weight: 700; color: #2C2A5C; line-height: 1.3; font-family: Arial, sans-serif;">
                                Action Required: Final Payment Failure
                            </h1>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                Hi {{firstName}},
                            </p>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                We’ve tried {{attemptsCount}} times to process your payment of {{amount}} {{currency}}
                                for your {{planName}} subscription, but unfortunately, the transaction was unsuccessful.
                            </p>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                To avoid an interruption in service and keep your account active, please update your
                                billing details in your account settings as soon as possible.
                            </p>
                        </td>
                    </tr>

                    <!-- FOOTER -->
                    {{> footer}}
                </table>
            </td>
        </tr>
    </table>
</body>

</html>