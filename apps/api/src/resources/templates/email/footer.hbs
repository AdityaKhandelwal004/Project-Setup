<!-- GET THE APP SECTION -->
<tr>
    <td align="center" style="padding: 20px 60px;">
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
            <tr>
                <td align="center">
                    <h2 style="margin: 0 0 10px 0; font-size: 20px; font-weight: 700; color: #6A40E5; font-family: Arial, sans-serif;">Get the Obiemoney app!</h2>
                    
                    <p style="margin: 0 0 20px 0; font-size: 14px; color: #666666; line-height: 1.5; font-family: Arial, sans-serif;">Get the most of Obiemoney by installing the mobile app.<br>You can log in by using your existing email address and password.</p>
                    
                    <!-- App Store Buttons -->
                    <table role="presentation" border="0" cellpadding="0" cellspacing="0" align="center">
                        <tr>
                            <td align="center" style="padding: 5px;">
                                <a href="https://www.apple.com/in/app-store" target="_blank">
                                    <img src="https://cdn.obiemoney.com/user-email-icons/app-store.png" alt="Download on the App Store" width="135" height="40" style="display: block; border: 0; outline: none;" />
                                </a>
                            </td>
                            <td align="center" style="padding: 5px;">
                                <a href="https://play.google.com/store/apps" target="_blank">
                                    <img src="https://cdn.obiemoney.com/user-email-icons/google-play.png" alt="Get it on Google Play" width="135" height="40" style="display: block; border: 0; outline: none;" />
                                </a>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </td>
</tr>

