<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#if emailTitle}}{{emailTitle}}{{else}}Obiemoney{{/if}}</title>
    <!--[if mso]>
    <style type="text/css">
        table { border-collapse: collapse; }
        .divider { height: 1px !important; }
    </style>
    <![endif]-->
</head>

<body
    style="margin: 0; padding: 0; width: 100%; background-color: #F5F5F5; font-family: Arial, sans-serif; -webkit-font-smoothing: antialiased;">
    <!-- Wrapper Table -->
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
        style="background-color: #F5F5F5;">
        <tr>
            <td align="center" style="padding: 40px 20px;">
                <!-- Container Table -->
                <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="700"
                    style="max-width: 700px; background-color: #FFFFFF; border-radius: 12px; overflow: hidden;">
                    <!-- HEADER -->
                    {{> header}}
                    <!-- MAIN CONTENT -->
                    <tr>
                        <td align="center" style="padding: 30px 60px;" align="left">
                            <h1
                                style="margin: 0 0 20px 0; font-size: 26px; font-weight: 700; color: #2C2A5C; line-height: 1.3; font-family: Arial, sans-serif;">
                                You’re One Step Closer to Financial Clarity
                            </h1>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                Hi {{firstName}},
                            </p>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                Thank you for your payment! We have successfully processed your transaction of
                                <strong>{{amount}} {{currency}}</strong>.
                            </p>
                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                                By maintaining your subscription, you’re staying committed to your 9-step financial
                                roadmap. Whether you're building your safety net, eliminating debt, or optimizing your
                                investments, we’re proud to be your digital companion on this journey toward financial
                                confidence.
                            </p>

                            <div
                                style="margin: 25px 0; padding: 20px; background-color: #F9F7FF; border-radius: 8px; border: 1px solid #E6E0FF; text-align: left;">
                                <p
                                    style="margin: 0; font-size: 14px; color: #2C2A5C; font-family: Arial, sans-serif; line-height: 1.5;">
                                    <strong>What’s Next?</strong><br />
                                    Head over to your dashboard to check your progress. Remember, financial resilience
                                    is built one step at a time, and you're doing great!
                                </p>
                            </div>

                            <table border="0" cellspacing="0" cellpadding="0" align="center" style="margin-top: 10px;">
                                <tr>
                                    <td align="center" bgcolor="#100937"
                                        style="padding: 12px 30px; border-radius: 6px;">
                                        <a href="{{url}}" target="_blank"
                                            style="font-family: Arial, sans-serif; font-size: 16px; font-weight: bold; color: #FFFFFF; text-decoration: none; display: inline-block;">
                                            Go to My Dashboard
                                        </a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <!-- FOOTER -->
                    {{> footer}}
                </table>
            </td>
        </tr>
    </table>
</body>

</html>