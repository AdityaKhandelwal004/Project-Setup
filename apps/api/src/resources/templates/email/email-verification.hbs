<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{#if emailTitle}}{{emailTitle}}{{else}}Template{{/if}}</title>
  <!--[if mso]>
    <style type="text/css">
        table { border-collapse: collapse; }
        .divider { height: 1px !important; }
    </style>
    <![endif]-->
</head>

<body
  style="margin: 0; padding: 0; width: 100%; background-color: #f5f5f5; font-family: Arial, sans-serif; -webkit-font-smoothing: antialiased;">
  <!-- Wrapper Table -->
  <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f5f5f5;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <!-- Container Table -->
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="700"
          style="max-width: 700px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

          <!-- HEADER -->
          {{> header}}

          <!-- MAIN CONTENT -->
          <tr>
            <td align="center" style="padding: 30px 60px;">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td align="center">
                    <h1
                      style="margin: 0 0 20px 0; font-size: 26px; font-weight: 700; color: #2C2A5C; line-height: 1.3; font-family: Arial, sans-serif;">
                      Verify Your Email Address</h1>
                    <img style="margin: 0 0 20px 0; width: 262px; height: 274px;"
                      src="https://cdn.template.com/user-email-icons/email-icon.png" alt="Template" />

                    <p
                      style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                      Hi {{name}},</p>

                    <p
                      style="margin: 0 0 15px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                      Welcome to Template! We're excited to have you on board. Please confirm your email address to
                      activate your account and get started.</p>

                    <table role="presentation" border="0" cellpadding="0" cellspacing="0" style="margin: 20px auto;">
                      <tr>
                        <td align="center" style="border-radius: 6px; background-color: #100937;">
                          <a href="{{url}}" target="_blank"
                            style="display: inline-block; padding: 15px 40px; font-size: 16px; color: #ffffff; text-decoration: none; font-weight: bold; font-family: Arial, sans-serif;">Confirm
                            Email Address</a>
                        </td>
                      </tr>
                    </table>

                    <p
                      style="margin: 15px 0 5px 0; font-size: 14px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                      If the button above doesn't work, copy and paste this link into your browser:</p>

                    <p
                      style="margin: 0 0 15px 0; font-size: 13px; color: #6A40E5; line-height: 1.6; font-family: Arial, sans-serif; word-break: break-all;">
                      <a href="{{url}}" style="color: #6A40E5; text-decoration: underline;">{{url}}</a>
                    </p>

                    <p
                      style="margin: 15px 0 10px 0; font-size: 15px; color: #666666; line-height: 1.6; font-family: Arial, sans-serif;">
                      For your security, this link will expire in
                      {{validity}}
                      minutes.</p>

                    <p
                      style="margin: 0; font-size: 14px; color: #999999; line-height: 1.6; font-family: Arial, sans-serif;">
                      If you did not sign up for an Template account, you can safely ignore this email.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- FOOTER -->
          {{> footer}}

        </table>
      </td>
    </tr>
  </table>
</body>

</html>