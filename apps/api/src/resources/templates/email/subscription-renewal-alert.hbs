<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#if emailTitle}}{{emailTitle}}{{else}}Obiemoney{{/if}}</title>
    <!--[if mso]>
    <style type="text/css">
        table { border-collapse: collapse; }
        .divider { height: 1px !important; }
    </style>
    <![endif]-->
</head>

<body
    style="margin: 0; padding: 0; width: 100%; background-color: #f5f5f5; font-family: Arial, sans-serif; -webkit-font-smoothing: antialiased;">

    <!-- Wrapper -->
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f5f5f5;">
        <tr>
            <td align="center" style="padding: 40px 20px;">

                <!-- Container -->
                <table role="presentation" cellpadding="0" cellspacing="0" width="700"
                    style="max-width: 700px; background-color: #ffffff; border-radius: 12px; overflow: hidden;">

                    <!-- HEADER -->
                    {{> header}}

                    <!-- MAIN CONTENT -->
                    <tr>
                        <td align="center" style="padding: 30px 60px;">

                            <h1
                                style="margin: 0 0 20px 0; font-size: 26px; font-weight: 700; color: #2C2A5C; line-height: 1.3; font-family: Arial, sans-serif;">
                                Keep Your Financial Journey on Track
                            </h1>

                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #555555; line-height: 1.6; font-family: Arial, sans-serif; text-align: left;">
                                Hi {{firstName}},
                            </p>

                            <p
                                style="margin: 0 0 15px 0; font-size: 15px; color: #555555; line-height: 1.6; font-family: Arial, sans-serif; text-align: left;">
                                This is a friendly reminder that your <strong>{{planName}}</strong> subscription is
                                scheduled for renewal. Staying active ensures you continue to have
                                full access to <br> your financial roadmap.
                            </p>

                            <div
                                style="margin: 25px 0; padding: 20px; background-color: #F9F7FF; border-radius: 8px; border: 1px solid #E6E0FF; text-align: left;">
                                <p
                                    style="margin: 0; font-size: 15px; color: #2C2A5C; font-family: Arial, sans-serif; line-height: 1.5;">
                                    <strong>Renewal Date:</strong> {{expiryDate}}<br />
                                    <strong>Time Remaining:</strong> {{remainingDays}} days
                                </p>
                            </div>

                            <p
                                style="margin: 20px 0 15px 0; font-size: 15px; color: #555555; line-height: 1.6; font-family: Arial, sans-serif; text-align: left;">
                                To maintain uninterrupted access to your financial dashboard and safety net tools,
                                please ensure your payment method is up to date.
                            </p>

                            <table border="0" cellspacing="0" cellpadding="0" align="center" style="margin-top: 20px;">
                                <tr>
                                    <td align="center" bgcolor="#100937"
                                        style="padding: 12px 30px; border-radius: 6px;">
                                        <a href="{{url}}" target="_blank"
                                            style="font-family: Arial, sans-serif; font-size: 16px; font-weight: bold; color: #ffffff; text-decoration: none; display: inline-block;">
                                            Manage Billing
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p
                                style="margin: 25px 0 0 0; font-size: 14px; color: #999999; line-height: 1.6; font-family: Arial, sans-serif; text-align: left;">
                                Thank you for letting Obiemoney be your digital companion in achieving financial
                                confidence.
                            </p>

                        </td>
                    </tr>

                    <!-- FOOTER -->
                    {{> footer}}

                </table>

            </td>
        </tr>
    </table>

</body>

</html>