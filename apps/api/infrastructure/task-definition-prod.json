{
    "executionRoleArn": "arn:aws:iam::312347353656:role/ecsTaskExecutionRole_prod",
    "containerDefinitions": [
        {
            "name": "api-prod",
            "image": ":ECR_IMAGE",
            "cpu": 0,
            "memory": 512,
            "portMappings": [
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "secrets": [
                {
                "name": "NODE_ENV",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/NODE_ENV"
                },
                {
                "name": "PORT",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/PORT"
                },
                {
                "name": "FEATURE_LEVEL",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/FEATURE_LEVEL"
                },
                {
                "name": "ALLOWED_ORIGINS",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/ALLOWED_ORIGINS"
                },
                {
                "name": "DB_USER",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/DB_USER"
                },
                {
                "name": "DB_PASSWORD",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/DB_PASSWORD"
                },
                {
                "name": "DB_HOST",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/DB_HOST"
                },
                {
                "name": "DB_NAME",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/DB_NAME"
                },
                {
                "name": "DB_PORT",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/DB_PORT"
                },
                {
                "name": "JWT_PRIVATE_KEY",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/JWT_PRIVATE_KEY"
                },
                {
                "name": "ENCRYPTION_KEY",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/ENCRYPTION_KEY"
                },
                {
                "name": "JWT_PUBLIC_KEY",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/JWT_PUBLIC_KEY"
                },
                {
                "name": "STRIPE_SECRET_KEY",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/STRIPE_SECRET_KEY"
                },
                {
                "name": "AWS_REGION",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/AWS_REGION"
                },
                {
                "name": "S3_UPLOADS_BUCKET_NAME",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/S3_UPLOADS_BUCKET_NAME"
                },
                {
                "name": "S3_VAULT_BUCKET_NAME",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/S3_VAULT_BUCKET_NAME"
                },
                {
                "name": "INVOICE_LAMBDA_ARN",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/INVOICE_LAMBDA_ARN"
                },
                {
                "name": "SENDGRID_API_KEY",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/SENDGRID_API_KEY"
                },
                {
                "name": "SENDGRID_FROM_EMAIL",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/SENDGRID_FROM_EMAIL"
                },
                {
                "name": "SENDGRID_FROM_NAME",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/SENDGRID_FROM_NAME"
                },
                {
                "name": "APP_BASEURL",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/APP_BASEURL"
                },
                {
                "name": "ADMIN_BASEURL",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/ADMIN_BASEURL"
                },
                {
                "name": "API_BASEURL",
                "valueFrom": "arn:aws:ssm:ap-southeast-2:312347353656:parameter/api/prod/API_BASEURL"
                }
            ],
            "essential": true,
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "api-prod",
                    "awslogs-region": "ap-southeast-2",
                    "awslogs-stream-prefix": "api"
                }
            }
        }
    ],
    "family": "api-prod",
    "taskRoleArn": "arn:aws:iam::312347353656:role/ecsTaskRole_prod",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512"
}